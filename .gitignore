# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
http.md

# production
/build
instructions.md
schemas.sql
# misc
.DS_Store
*.pem
*.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# not in production yet
app/admin/analytics
app/admin/finance
app/admin/people
app/admin/reports
app/admin/settings
app/admin/materials/*
!app/admin/materials/*.ts*
app/admin/orders/*
!app/admin/orders/*.ts*

# Database dumps & migration scripts (contain secrets)
*.sql
!supabase/migrations/*.sql
db-export/
supabase/.temp/

# One-off migration/fix scripts
check-*.js
fix-*.js
import-*.js
create-*.js
migrate-*.js
setup-*.js
full-import.js
retry-data.js
get-views.js
sync-databases.js
export_*.json